{
  "name": "@namlit-dev/ts_proto",
  "version": "1.0.0",
  "description": "TypeScript contracts generated from the shared Protocol Buffers schema",
  "packageManager": "bun@1.3.9",
  "type": "module",
  "main": "./generated/index.ts",
  "exports": {
    ".": "./generated/index.ts",
    "./*": "./generated/*"
  },
  "types": "./generated/index.ts",
  "files": [
    "generated/**/*.ts",
    "scripts/**/*.ts"
  ],
  "scripts": {
    "clean": "rm -rf generated",
    "generate": "bun run scripts/generate.ts",
    "test": "bun test",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "build": "bun run clean && bun run generate && bun run typecheck",
    "prepare": "bun run build"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "true-myth": "^9.3.1"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.26.1",
    "@bufbuild/protoc-gen-es": "^2.11.0",
    "@types/node": "^20.0.0",
    "bun-types": "^1.3.9",
    "typescript": "^5.3.0",
    "yaml": "^2.8.1"
  },
  "peerDependencies": {
    "typescript": ">=4.0.0"
  }
}
